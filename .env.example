# Jules Daemon Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Dataiku Mesh LLM (required for NL translation + agent loop) ---
JULES_LLM_BASE_URL=https://your-dataiku-host/public/api/projects/YOUR_PROJECT/llms/openai/v1/
JULES_LLM_API_KEY=your-dataiku-api-key
JULES_LLM_DEFAULT_MODEL=provider:connection:model

# SSL verification (set to false for self-signed certs)
JULES_LLM_VERIFY_SSL=false

# --- SSH Authentication ---
# Option 1: Single password for all hosts
JULES_SSH_PASSWORD=your-ssh-password

# Option 2: Per-host credentials file (see config/hosts.example.yaml)
# JULES_SSH_CREDENTIALS_FILE=~/.jules/ssh_credentials.yaml
